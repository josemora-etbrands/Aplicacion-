generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ET Brands Analysis — Schema v2
// ─────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("users")
}

model Product {
  id               String      @id @default(cuid())
  sku              String      @unique
  nombre           String

  // Metas de velocidad (del Excel "Revisión velocidades")
  velocidadInicial Float       // Meta 1: venta semanal mínima esperada
  velocidadMadura  Float       // Meta 2: venta semanal en estado maduro

  // Métricas financieras (fuente: ProfitGuard - Productos)
  margenPct        Float       @default(0)   // Margen % (ej: 33.7)
  acos             Float       @default(0)   // Publicidad/Ingresos ratio (ej: 0.049)
  precioVenta      Float       @default(0)   // Precio de venta ML calculado
  publicidad       Float       @default(0)   // Gasto en publicidad CLP
  ventas           Float       @default(0)   // Ingresos netos por ventas CLP
  ingresos         Float       @default(0)   // Ingresos brutos CLP

  // Inventario
  stock            Int         @default(0)
  nota             String?

  // Métricas ML opcionales
  visitas          Int         @default(0)
  conversion       Float       @default(0)
  posicionSEO      Int?
  calificacion     Float       @default(0)

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  actionLogs       ActionLog[]
  weeklySales      WeeklySales[]
  palancaLogs      PalancaLog[]

  @@map("products")
}

model WeeklySales {
  id        String  @id @default(cuid())
  productId String
  year      Int
  week      Int
  value     Float   @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, year, week])
  @@map("weekly_sales")
}

enum CategoriaPalanca {
  EXPOSICION
  CONVERSION
}

model Palanca {
  id          String           @id @default(cuid())
  nombre      String           @unique
  categoria   CategoriaPalanca
  descripcion String
  createdAt   DateTime         @default(now())
  actionLogs  ActionLog[]
  @@map("palancas")
}

model PalancaLog {
  id          String   @id @default(cuid())
  productId   String
  tipoPalanca String
  fechaInicio DateTime
  comentario  String?
  createdAt   DateTime @default(now())
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("palanca_logs")
}

enum EjecutadoPor {
  USUARIO
  IA
}

model ActionLog {
  id           String       @id @default(cuid())
  productId    String
  palancaId    String
  ejecutadoPor EjecutadoPor
  impacto      Float?
  notas        String?
  createdAt    DateTime     @default(now())
  product      Product      @relation(fields: [productId], references: [id])
  palanca      Palanca      @relation(fields: [palancaId], references: [id])
  @@map("action_logs")
}
